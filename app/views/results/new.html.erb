<div class="container">
    <div class="center">
        <div class="form">
            <%= simple_form_for [@listing, @result] do |f| %>
            <%= f.input :comment %>
            <%= f.input :result_song, as: :file %>
            <%= f.submit 'Upload your song', class: 'blue-gradient-button' %>
            <% end %>
        </div>
    </div>
    <div class="row">
        <div class="col-sm">
            <%= link_to "home", root_path, class: "btn btn-outline-primary btn-improved" %>
        </div>
    </div>
</div>