<h1>Mon gros index</h1>
    <div class="container">
        <div>
          <%= form_tag listings_path, method: :get, class: "form-inline" do %>
          <div class="form-group">
            <%= text_field_tag :instrument,
            params[:instrument],
            class: "form-control mg",
            placeholder: "Which instrument ?" %>
          </div>
          <div class="form-group">
            <%= text_field_tag :band,
            params[:band],
            class: "form-control mg",
            placeholder: "Which band ?" %>
          </div>
          <div class="form-group">
            <%= text_field_tag :style,
            params[:style],
            class: "form-control mg",
            placeholder: "Which style ?" %>
          </div>
          <div class="form-group">
            <%= text_field_tag :location,
            params[:location],
            class: "form-control mg",
            placeholder: "where ?" %>
          </div>
            <%= submit_tag "Search", class: "btn btn-primary btn-improved" %>
          <% end %>
        </div>
        <br>
        <div class="itemo">
         <% if current_user %>
          Hello <%= current_user.username %>
         <%end%>
        </div>
        <div class="container">
          <% @listings.each do |listing|%>
          <div >
            <div class="itemo flexcenter">
              <div id="info">
                <div class="itemo">
                  <p>user : <%= listing.user.username %> (<%= listing.user.first_name %> <%= listing.user.last_name %>)<br>  
                  band : <%= listing.band %><br>       
                  style : <%= listing.style %><br>           
                  instrument : <%= listing.instrument %><br>               
                  location : <%= listing.location %><br>
                  comment : <%= listing.comment %></p>
                </div>
              </div>
              <div id="action">
                <div class="itemo">
                  <h3 class="flexcenter">ORIGINAL TRACK</h3>
                  <div class="flexcenter">
                    <% if listing.original_song.attached? %>
                      <audio controls>
                        <source src="http://localhost:3000<%=url_for(listing.original_song)%>" type="audio/mpeg">
                      </audio>
                    <% else %>
                      <p>No track...</p>
                    <% end %>
                  </div>
                </div>
                <div class="flexcenter">
                  <%= link_to "listen to results", listing_results_path(listing), class: "btn btn-primary btn-improved" %>
                  <%= link_to "upload your work ", new_listing_result_path(listing), class: "btn btn-primary btn-improved" %>
                </div>
              </div>
            </div>
          </div>
          <% end %>
        </div>

        <div class="row">
            <div class="col-sm">
                <%= link_to "home", root_path, class: "btn btn-outline-primary btn-improved" %>
            </div>
        </div>
    </div>