<div class="center">
    <div class="form">
            <%= form_for(@listing) do |f| %>
        <div class="form-group">
            <%= f.label :style %>
            <%= f.text_field :style %>
        </div>
        <div class="form-group">
            <%= f.label :instrument %>
            <%= f.text_field :instrument %>
        </div>
        <div class="form-group">
            <%= f.label :band %>
            <%= f.text_field :band %>
        </div>
            <%= f.submit %>
            <% end %>
    </div>
</div>