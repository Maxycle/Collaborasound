<div class="container">
    <div class="center">
        <div class="form">
            <%= simple_form_for(@listing) do |f| %>
            <%= f.input :instrument %>
            <%= f.input :style %>
            <%= f.input :band %>
            <%= f.input :location %>
            <%= f.submit 'Create listing', class: 'blue-gradient-button' %>
            <% end %>
        </div>
    </div>
    <div class="row">
        <div class="col-sm">
            <%= link_to "home", root_path, class: "btn btn-outline-primary btn-improved" %>
        </div>
    </div>
</div>